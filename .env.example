PORT=3000

# URL base para la API (por defecto Ollama local: http://localhost:11434/v1)
# Si usas OpenAI, descomenta y usa: https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# API Key (Ollama no la requiere, puedes dejar cualquier valor)
# Para OpenAI, pon tu clave real: sk-...
OPENAI_API_KEY=ollama

# Modelo por defecto (ej. para ollama usa llama3, para OpenAI usa gpt-3.5-turbo)
DEFAULT_MODEL=llama3
